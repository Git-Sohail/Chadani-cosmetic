DATABASE_URL="postgresql://user:password@localhost:5432/cosmetic_store"
JWT_SECRET="change-this-to-a-long-random-secret"

# SMTP (Nodemailer) — never commit real credentials
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Chadani Cosmetic <no-reply@yourdomain.com>"

# If SMTP credentials fail in development, OTP is printed in the backend console
SMTP_FALLBACK_ON_ERROR=true

# Optional: link in welcome emails
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Authorized redirect URI in Google Console (backend callback)
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary (optional — invalid credentials fall back to local /uploads storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
BACKEND_PUBLIC_URL=http://localhost:5000
